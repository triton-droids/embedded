<?xml version="1.0"?>
<robot name="urdf_test_arm">

  <!-- Humanoid arm URDF. Meshes are exported in CAD assembly coordinates, so visual/collision origins compensate each link frame offset. -->

  <material name="arm_base_gray">
    <color rgba="0.55 0.57 0.60 1.0"/>
  </material>

  <material name="arm_shoulder_blue">
    <color rgba="0.20 0.45 0.85 1.0"/>
  </material>

  <material name="arm_upper_silver">
    <color rgba="0.75 0.75 0.78 1.0"/>
  </material>

  <material name="arm_lower_green">
    <color rgba="0.25 0.65 0.35 1.0"/>
  </material>

  <material name="arm_wrist_orange">
    <color rgba="0.90 0.55 0.20 1.0"/>
  </material>

  <link name="base_dummy_link"/>

  <joint name="base_dummy_to_base_joint" type="fixed">
    <parent link="base_dummy_link"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://humanoid_arm_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="arm_base_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://humanoid_arm_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.000020 -0.000057 0.013925" rpy="0 0 0"/>
      <mass value="0.886350"/>
      <inertia ixx="8.550e-4" ixy="-6.9698e-7" ixz="-5.74496e-6" iyy="8.934e-4" iyz="-6.0698e-7" izz="1.117e-3"/>
    </inertial>
  </link>

  <link name="shoulder_link">
    <visual>
      <origin xyz="-0.000020 0.000058 -0.013738" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://humanoid_arm_description/meshes/shoulder_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="arm_shoulder_blue"/>
    </visual>
    <collision>
      <origin xyz="-0.000020 0.000058 -0.013738" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://humanoid_arm_description/meshes/shoulder_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.009494 -0.000709 0.103481" rpy="0 0 0"/>
      <mass value="2.421050"/>
      <inertia ixx="4.728e-3" ixy="3.326497e-5" ixz="-2.117e-5" iyy="4.775e-3" iyz="-6.01496e-6" izz="3.162e-3"/>
    </inertial>
  </link>

  <link name="upper_arm_link">
    <visual>
      <origin xyz="0.007352 0.000058 -0.132114" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://humanoid_arm_description/meshes/upper_arm_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="arm_upper_silver"/>
    </visual>
    <collision>
      <origin xyz="0.007352 0.000058 -0.132114" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://humanoid_arm_description/meshes/upper_arm_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.003690 0.101836 -0.000771" rpy="0 0 0"/>
      <mass value="0.714674"/>
      <inertia ixx="2.332e-3" ixy="5.054617e-5" ixz="-8.13e-7" iyy="1.087e-3" iyz="1.823718e-5" izz="2.687e-3"/>
    </inertial>
  </link>

  <link name="lower_arm_link">
    <visual>
      <origin xyz="0.002227 -0.125482 -0.130902" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://humanoid_arm_description/meshes/lower_arm_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="arm_lower_green"/>
    </visual>
    <collision>
      <origin xyz="0.002227 -0.125482 -0.130902" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://humanoid_arm_description/meshes/lower_arm_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.001133 0.112638 0.001957" rpy="0 0 0"/>
      <mass value="0.811951"/>
      <inertia ixx="1.447e-3" ixy="7.868620e-5" ixz="-5.44373e-6" iyy="7.411e-4" iyz="6.073962e-5" izz="1.469e-3"/>
    </inertial>
  </link>

  <link name="wrist_link">
    <visual>
      <origin xyz="0.003075 -0.253286 -0.137246" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://humanoid_arm_description/meshes/wrist_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="arm_wrist_orange"/>
    </visual>
    <collision>
      <origin xyz="0.003075 -0.253286 -0.137246" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://humanoid_arm_description/meshes/wrist_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.006476 0.103132 -0.010439" rpy="0 0 0"/>
      <mass value="0.745852"/>
      <inertia ixx="3.238e-3" ixy="3.132e-4" ixz="5.336596e-5" iyy="7.462e-4" iyz="-2.178e-4" izz="3.023e-3"/>
    </inertial>
  </link>

  <joint name="base_to_shoulder_joint" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0.000020 -0.000058 0.013738" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="30.0" velocity="2.0"/>
  </joint>

  <joint name="shoulder_to_upper_arm_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="-0.007372 0 0.118376" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.0" upper="2.0" effort="30.0" velocity="2.0"/>
  </joint>

  <joint name="upper_arm_to_lower_arm_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="lower_arm_link"/>
    <origin xyz="0.005125 0.125540 -0.001212" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="2.5" effort="30.0" velocity="2.0"/>
  </joint>

  <joint name="lower_arm_to_wrist_joint" type="revolute">
    <parent link="lower_arm_link"/>
    <child link="wrist_link"/>
    <origin xyz="-0.000848 0.127804 0.006344" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="15.0" velocity="2.0"/>
  </joint>

  <ros2_control name="HumanoidArmSystem" type="system">
    <hardware>
      <plugin>mock_components/GenericSystem</plugin>
    </hardware>
    <joint name="base_to_shoulder_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="shoulder_to_upper_arm_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="upper_arm_to_lower_arm_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lower_arm_to_wrist_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>
